{
  "name": "backoffice-automation",
  "version": "1.0.0",
  "description": "Playwright automation for Pickup Coffee Back Office (staging)",
  "scripts": {
    "test": "playwright test --workers=1",
    "launch": "playwright test -g \"login page loads\" --project=login --headed",
    "test:headed": "playwright test --headed --workers=1",
    "test:headed:orders": "playwright test --headed --workers=1 --project=orders",
    "test:headed:staff": "playwright test --headed --workers=1 --project=staff",
    "test:headed:branch": "playwright test --headed --workers=1 --project=branch",
    "test:headed:staff:watch": "PW_SLOW_MO_MS=200 playwright test --headed --workers=1 --project=staff",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report"
  },
  "keywords": [
    "playwright",
    "automation",
    "e2e"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}
